# ─── AppSumo API credentials ─────────────────────────────────────────────────
# Obtain these from your AppSumo vendor dashboard after creating your listing.
# OAuth2 client credentials grant is used to authenticate against AppSumo's API.
APPSUMO_CLIENT_ID=your_appsumo_client_id_here
APPSUMO_CLIENT_SECRET=your_appsumo_client_secret_here

# ─── Demo / development bypass ───────────────────────────────────────────────
# Any license key matching this value will be accepted without calling AppSumo.
# Useful for testing the UI flow locally before you have real credentials.
# Remove or leave empty in production.
DEMO_LICENSE_KEY=DEMO-0000-0000-0000

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001

# Only needed in development (Vite runs on a different port and proxies /api).
ALLOWED_ORIGIN=http://localhost:5173
